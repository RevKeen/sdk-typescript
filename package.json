{
  "name": "@revkeen/sdk",
  "version": "1.20260716.1322",
  "description": "RevKeen TypeScript SDK — Know What You Keep",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.mjs",
      "require": "./dist/webhooks.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.mjs",
      "require": "./dist/auth.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.mjs",
      "require": "./dist/ai.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "generate:webhooks": "node scripts/sync-webhooks.mjs",
    "generate:client": "openapi-ts --file openapi-ts.config.ts",
    "generate:wrapper": "tsx scripts/generate-resources.ts",
    "generate": "pnpm generate:webhooks && pnpm generate:client && pnpm generate:wrapper",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "ai": "^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/revkeen/sdk"
  },
  "keywords": [
    "revkeen",
    "payments",
    "billing",
    "sdk",
    "api"
  ]
}
